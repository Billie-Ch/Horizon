{
  "ai": {
    "provider": "openai",
     "base_url": "https://www.tokenrouter.tech/v1", 
    "model": "gpt-5.4-mini",
    "api_key_env": "OPENAI_API_KEY",
    "language": "zh"
  },
  "sources": {
    "rss": [
      {
        "name": "Supply Chain Dive",
        "url": "https://www.supplychaindive.com/feeds/news/",
        "category": "industry-news"
      },
      {
        "name": "Manufacturing.net",
        "url": "https://www.manufacturing.net/homepage/rss.xml",
        "category": "industry-news"
      },
      {
        "name": "The Robot Report",
        "url": "https://www.therobotreport.com/feed/",
        "category": "automation"
      }
    ],
    "hacker_news": [],
    "reddit": [
      {
        "name": "r/supplychain",
        "subreddit": "supplychain",
        "sort": "hot"
      },
      {
        "name": "r/manufacturing",
        "subreddit": "manufacturing",
        "sort": "top"
      }
    ]
  },
  "filter": {
    "keywords": ["logistics", "semiconductor", "factory", "inventory", "shipping"],
    "min_score": 0.6
  },
  "output": {
    "format": "markdown",
    "save_to_file": true
  }
}
